# Opcjonalnie: skopiuj do `.env.development` — wyłącza source-map-loader w `npm start`
# (naprawia znikający plik index.mjs / błędny cache). Zobacz .env.development w repo.
# GENERATE_SOURCEMAP=false

# API Configuration
# Development: `src/setupProxy.js` przekierowuje `/api` na backend (CRA ignoruje pole "proxy" w package.json, gdy jest setupProxy).
REACT_APP_API_URL=/api

# Port/host backendu przy `npm start` (gdy API nie jest na localhost:3001):
# ARBOR_API_PROXY_TARGET=http://localhost:3003
#
# Lokalny serwer z repo (wyceny, wideo, rozliczenie, demo login):
#   cd server && npm install && npm start   → domyślnie :3001
# Z frontu jednocześnie: npm run dev:full
# Konta demo (hasło = login): admin, oleg, kierownik, specjalista

# Dla bezpośredniego połączenia z backendem (bez proxy dev):
# REACT_APP_API_URL=http://localhost:3001/api

# Dla produkcji / Render (root render.yaml ustawia to z URL backendu — możesz podać sam host HTTPS, /api dopnie front):
# REACT_APP_API_URL=https://twoja-usluga-backend.onrender.com
# REACT_APP_API_URL=https://twoja-domena.pl/api

# --- Twoja Kommo (krok po kroku): web/docs/kommo-wlasna-instancja.md ---
#
# Link do aplikacji Kommo (CRM) — przycisk na stronie /crm (tylko front):
# REACT_APP_KOMMO_APP_URL=https://twoj-subdomena.kommo.com

# Integracja Kommo / webhooki (backend web/server; m.in. CMR po API jeśli używasz):
# KOMMO_WEBHOOK_URL=https://twoj-webhook-kommo.example/hook
# (opcjonalnie) osobny webhook tylko dla CRM (zlecenie / klient); gdy pusty — używany jest KOMMO_WEBHOOK_URL:
# KOMMO_CRM_WEBHOOK_URL=https://twoj-make-scenariusz-crm.example/hook
# (opcjonalnie) nagłówek autoryzacyjny webhooka:
# KOMMO_WEBHOOK_SECRET_HEADER=X-Webhook-Secret
# KOMMO_WEBHOOK_SECRET=super_tajny_token
#
# (opcjonalnie) mapowanie pod lead w Kommo:
# KOMMO_PIPELINE_ID=1234567
# KOMMO_STATUS_ID=2345678
# KOMMO_RESPONSIBLE_USER_ID=3456789
# KOMMO_TAGS=CMR,Arbor,Transport
#
# (opcjonalnie) custom fields IDs:
# KOMMO_CF_CMR_NUMBER_ID=111111
# KOMMO_CF_ORDER_ID=111112
# Oddział w Kommo (wartość z powiązanego zlecenia, nie z formularza CMR):
# KOMMO_CF_BRANCH_ID=111113
# KOMMO_CF_PLATE_ID=111114
# KOMMO_CF_DRIVER_ID=111115
# KOMMO_CF_STATUS_ID=111116
# KOMMO_CF_LOAD_DATE_ID=111117
# KOMMO_CF_UNLOAD_DATE_ID=111118
# KOMMO_CF_GOODS_SUMMARY_ID=111119
#
# CRM (zlecenie / klient — ten sam webhook co CMR, inny event w JSON):
# KOMMO_CRM_TAGS=Arbor,CRM
# KOMMO_CF_KLIENT_RECORD_ID=111120
# KOMMO_CF_PHONE_ID=111121
