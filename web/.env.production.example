# Copy to `web/.env.production`, set the URL, then build:
# npm run build -w arbor-web

# Preferred Vite variable. Use the full backend API URL.
VITE_API_URL=https://api.twoja-domena.pl/api

# Same-origin deploy with reverse proxy:
# VITE_API_URL=/api

# Optional CRM button target in the web panel.
# VITE_KOMMO_APP_URL=https://twoja-firma.kommo.com

# Legacy `REACT_APP_API_URL` still works through vite.config.js, but new
# deployments should use `VITE_API_URL`.
