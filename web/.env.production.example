# Skopiuj do pliku `.env.production` (w katalogu głównym projektu), uzupełnij URL i zbuduj: npm run build
#
# Pełny adres backendu z końcówką /api (tak jak oczekuje axios w src/api.js)
REACT_APP_API_URL=https://twoja-domena.pl/api

# Jeśli backend jest na tej samej domenie co panel, często:
# REACT_APP_API_URL=/api
# (wymaga wtedy reverse proxy na serwerze: /api → backend)
