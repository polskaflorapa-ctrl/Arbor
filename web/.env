# API Configuration
# Frontend (PORT) - requests to /api in dev go through Vite proxy to OS backend (default :3000).
# On 504/502 for /api/*: run `npm run os` or `npm run dev:all` (frontend + API).
PORT=3002
REACT_APP_API_URL=/api
# Optional when API is not on :3000:
# ARBOR_API_PROXY_TARGET=http://127.0.0.1:3000
# Full URL instead of proxy (for another host/port):
# REACT_APP_API_URL=http://localhost:3000/api
# Production:
# REACT_APP_API_URL=https://twoja-domena.pl/api
