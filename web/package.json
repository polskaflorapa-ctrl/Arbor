{
  "name": "arbor-web",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "axios": "^1.14.0",
    "i18next": "^23.16.8",
    "i18next-browser-languagedetector": "^7.2.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-i18next": "^14.1.3",
    "react-router-dom": "6.30.3",
    "react-scripts": "5.0.1",
    "web-vitals": "^2.1.4",
    "xlsx": "^0.18.5"
  },
  "scripts": {
    "clean:cache": "node -e \"const fs=require('fs');['node_modules/.cache','build'].forEach(p=>{try{fs.rmSync(p,{recursive:true,force:true});}catch(e){}});\"",
    "start": "react-scripts start",
    "preview": "npm run build && npx --yes serve -s build -l 4173",
    "build": "react-scripts build",
    "verify": "npm run build && npm test -- --watchAll=false",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "server": "npm --prefix server start",
    "server:dev": "npm --prefix server run dev",
    "dev:full": "node ./scripts/dev-full-smart.cjs",
    "status:web": "node ./scripts/status-web.cjs",
    "status:web:json": "node ./scripts/status-web.cjs --json",
    "smoke:kommo:crm": "node ./scripts/smoke-kommo-crm.cjs"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "overrides": {
    "react-router": "6.30.3",
    "react-router-dom": "6.30.3"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
