{
  "name": "arbor-web",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.11",
    "@mui/material": "^7.3.9",
    "@sentry/react": "^9.10.0",
    "@sentry/vite-plugin": "^3.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "axios": "^1.16.1",
    "i18next": "^23.16.8",
    "i18next-browser-languagedetector": "^7.2.1",
    "lucide-react": "^1.20.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-i18next": "^14.1.3",
    "react-router-dom": "6.30.4",
    "web-vitals": "^2.1.4"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^27.2.0",
    "vite": "^8.0.16",
    "vitest": "^4.0.15"
  },
  "scripts": {
    "clean:cache": "node -e \"const fs=require('fs');['node_modules/.cache','node_modules/.vite','build'].forEach(p=>{try{fs.rmSync(p,{recursive:true,force:true});}catch(e){}});\"",
    "start": "node ./scripts/run-vite.cjs dev --host 0.0.0.0",
    "preview": "npm run build && node ./scripts/run-vite.cjs preview --host 0.0.0.0 --port 4173",
    "build": "node ./scripts/run-vite.cjs build",
    "verify": "npm run build && npm test",
    "test": "node ./scripts/run-vitest.cjs run",
    "test:watch": "node ./scripts/run-vitest.cjs watch",
    "server": "npm --prefix server start",
    "server:dev": "npm --prefix server run dev",
    "dev:full": "node ./scripts/dev-full-smart.cjs",
    "status:web": "node ./scripts/status-web.cjs",
    "status:web:json": "node ./scripts/status-web.cjs --json",
    "smoke:routes": "node ./scripts/smoke-routes.cjs",
    "smoke:platform": "node ./scripts/smoke-routes.cjs",
    "smoke:tti": "node ./scripts/smoke-tti.cjs",
    "smoke:demo:e2e": "node ./scripts/run-vitest.cjs run src/api.test.js -t \"demo critical path\"",
    "smoke:kommo:crm": "node ./scripts/smoke-kommo-crm.cjs"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "overrides": {
    "react-router": "6.30.4",
    "react-router-dom": "6.30.4"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
