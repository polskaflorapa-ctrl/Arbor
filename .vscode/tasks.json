{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "mobile: Expo start",
      "type": "shell",
      "command": "npm run start",
      "options": {
        "cwd": "${workspaceFolder}/mobile",
        "env": {
          "EXPO_NO_TELEMETRY": "1"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      },
      "problemMatcher": []
