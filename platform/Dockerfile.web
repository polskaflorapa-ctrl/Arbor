# Arbor OS — front (host prototypów + prototypy) zbudowany przez Vite, serwowany przez nginx
FROM node:24-alpine AS build
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
# buduje dist/ (index.html + assets + dist/prototypes/*.html)
RUN npm run build

FROM nginx:alpine
COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
