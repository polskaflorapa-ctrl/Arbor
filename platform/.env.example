ARBOR_API_PORT=8790
ARBOR_WEB_PORT=5175
VITE_ARBOR_API_URL=http://127.0.0.1:8790
ARBOR_JWT_SECRET=change-this-long-random-secret
ARBOR_PORTAL_SECRET=change-this-long-random-secret
ARBOR_TOKEN_TTL_SECONDS=28800

# --- Bezpieczeństwo / RODO ---
# Klucz szyfrowania at-rest (nagrania/dokumenty). Wygeneruj: openssl rand -hex 32
ARBOR_ENCRYPTION_KEY=change-this-32-byte-random-secret
# Okno retencji danych w dniach (audyt/powiadomienia/outbox czyszczone przy starcie).
ARBOR_RETENTION_DAYS=90

# --- Integracje produkcyjne (sekrety TYLKO po stronie serwera) ---
# Telefonia Zadarma (panel Zadarma → Ustawienia → API). Bez kluczy: tryb demo (symulacja).
ZADARMA_KEY=
ZADARMA_SECRET=
ZADARMA_SIP=
RECORDING_RETENTION_DAYS=90

# Analiza rozmów AI. Deepgram = STT PL + diaryzacja w jednym wywołaniu (preferowane);
# OpenAI = Whisper (STT, gdy brak Deepgram) + scoring (gpt-4o-mini). Bez kluczy: tryb demo.
DEEPGRAM_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Komunikacja klienta. Bez kluczy: manual/demo, bez realnej wysylki.
SMSAPI_TOKEN=
AWS_SES_FROM=

# Mapy i trasy ekip. Bez klucza: mapa/route planner dziala w trybie manualnym.
GOOGLE_MAPS_API_KEY=

# SaaS billing. Bez kluczy: Przelewy24 checkout jest symulowany.
P24_MERCHANT_ID=
P24_POS_ID=
P24_CRC=
P24_API_KEY=

# Pliki produkcyjne: nagrania, dokumenty, eksporty i backup artefaktow.
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# Monitoring produkcji.
SENTRY_DSN=

# Mobile release pipeline.
APPLE_TEAM_ID=
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=
APP_PUBLIC_URL=

ARBOR_ENABLE_DEV_RESET=0
ARBOR_DEV_RESET_SECRET=

# --- Konta startowe (wdrożenie produkcyjne) ---
# W NODE_ENV=production konta bez hasła NIE mogą się logować. Przy seedzie
# (npm run db:seed / docker compose exec api node server/seed-db.mjs) te zmienne
# nadają hasła kontom startowym: ADMIN dla administratorów, USERS dla pozostałych.
ARBOR_ADMIN_PASSWORD=
ARBOR_USERS_PASSWORD=

# --- Hardening HTTP ---
# Lista dozwolonych originów CORS po przecinku (puste = dowolny origin, tryb dev).
ARBOR_CORS_ORIGIN=
# Maksymalny rozmiar body JSON (domyślnie 5mb).
ARBOR_JSON_LIMIT=5mb
# Limit nieudanych prób logowania per IP+login w oknie czasowym (domyślnie 10 prób / 15 min).
ARBOR_LOGIN_ATTEMPT_LIMIT=10
ARBOR_LOGIN_ATTEMPT_WINDOW_MS=900000
# Za reverse-proxy (nginx/traefik): liczba hopów proxy, żeby req.ip był realnym IP klienta.
ARBOR_TRUST_PROXY=

# --- Baza danych (runtime) ---
# DB_DRIVER=sqlite (domyślnie, plik node:sqlite) albo postgres.
# Dla postgres ustaw DB_DRIVER=postgres ORAZ DATABASE_URL. W docker compose host bazy
# to nazwa serwisu 'db' (NIE localhost — localhost w kontenerze to sam kontener):
#   DB_DRIVER=postgres
#   DATABASE_URL=postgresql://arbor:TWOJE_HASLO@db:5432/arbor_os
# Następnie: npm run db:seed (zaseeduje wybraną bazę) i npm run dev:full.
DB_DRIVER=sqlite
# DATABASE_URL=   (wymagane tylko dla DB_DRIVER=postgres)

# Backup bazy: npm run db:backup (rotacja ARBOR_BACKUP_KEEP kopii w ARBOR_BACKUP_DIR).
ARBOR_BACKUP_KEEP=14
