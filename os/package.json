{
  "name": "arbor-os",
  "version": "1.0.0",
  "description": "Arbor OS — backend Node.js/Express dla aplikacji terenowej.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --runInBand",
    "test:critical-path": "jest --runInBand tests/critical-path-smoke.test.js",
    "test:integration": "node scripts/integration-db-check.js",
    "lint": "eslint .",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --runInBand",
    "smoke:user": "node scripts/create-smoke-user.js",
    "seed:demo-tasks": "node scripts/seed-demo-tasks.js",
    "seed:crm-inbox": "node scripts/seed-crm-inbox-demo.js",
    "seed:president-demo": "node scripts/seed-president-demo.js",
    "smoke:auth": "node scripts/smoke-auth-check.js",
    "smoke:basic": "powershell -ExecutionPolicy Bypass -File scripts/smoke-test.ps1 -BaseUrl http://127.0.0.1:3000",
    "smoke:basic:auth": "powershell -ExecutionPolicy Bypass -File scripts/smoke-test.ps1 -BaseUrl http://127.0.0.1:3000 -Login smoke_admin -Password Smoke123!",
    "smoke:prod": "node scripts/smoke-production-check.js",
    "smoke:p95": "node scripts/smoke-p95-check.js",
    "bootstrap:admin": "node scripts/bootstrap-admin.js",
    "prod:doctor": "node scripts/production-doctor.js",
    "backup:db": "node scripts/db-backup.js",
    "backup:db:check": "node scripts/db-backup.js --dry-run",
    "restore:db": "node scripts/db-restore.js",
    "restore:db:check": "node scripts/db-restore.js --dry-run",
    "smoke:field": "node scripts/smoke-field-flow.js",
    "smoke:telephony-scope": "node scripts/smoke-telephony-scope.js",
    "smoke:office": "node scripts/smoke-office-plan-flow.js",
    "smoke:signature": "node scripts/smoke-signature-protocol.js",
    "automations:daily": "node scripts/trigger-daily-automations.js",
    "automations:team-league": "node scripts/trigger-weekly-team-league.js",
    "smoke:full": "npm run smoke:user && npm run smoke:auth && npm run smoke:basic:auth",
    "smoke:operational": "node scripts/smoke-operational-flow.js",
    "smoke:f03": "node scripts/smoke-f0-3-m11.js",
    "flota:katalog": "node scripts/build-flota-katalog-from-xlsx.js",
    "db:migrate": "node scripts/apply-migrate.js",
    "seed:demo-full": "npm run db:migrate && npm run smoke:user && npm run seed:demo-tasks",
    "db:up": "node scripts/compose.cjs up -d",
    "db:down": "node scripts/compose.cjs down",
    "db:logs": "node scripts/compose.cjs logs -f postgres",
    "dev:stack": "node scripts/compose.cjs up -d && nodemon src/server.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@aws-sdk/client-s3": "^3.1033.0",
    "@aws-sdk/s3-request-presigner": "^3.1033.0",
    "archiver": "^7.0.1",
    "archiver-zip-encrypted": "^2.0.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "googleapis": "^171.4.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.8",
    "pdfkit": "^0.15.1",
    "pg": "^8.20.0",
    "prom-client": "^15.1.3",
    "rate-limit-redis": "^5.0.0",
    "redis": "^5.12.1",
    "twilio": "^5.4.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "jest": "^30.2.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.1.4",
    "xlsx": "^0.18.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
