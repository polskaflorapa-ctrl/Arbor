# --- Serwer ---
NODE_ENV=development
PORT=3000

# JWT (w produkcji obowiązkowy, silny)
JWT_SECRET=

# --- Baza (jedna z dwóch opcji) ---
# Render: wklej Internal Database URL z panelu Postgres (baza logiczna z render.yaml to arbor_db). Nie wgrywaj .env z lokalną nazwą bazy, jeśli inna niż na Renderze.
# DATABASE_URL=postgres://user:haslo@localhost:5432/arbor
DB_HOST=localhost
DB_PORT=5432
# Lokalnie z docker-compose.yml (npm run db:up): baza arbor_dev, hasło postgres
DB_NAME=arbor_dev
DB_USER=postgres
DB_PASSWORD=postgres

# --- CORS (opcjonalnie, lista po przecinku; * = dowolny origin) ---
# CORS_ORIGINS=http://localhost:5173,https://app.example.com

# --- Twilio SMS (opcjonalnie) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=

# Publiczny adres API (HTTPS), np. https://twoja-domena.pl lub tunel ngrok — wymagany do połączeń głosowych Twilio (TwiML)
# PUBLIC_BASE_URL=https://twoj-serwer.example

# Transkrypcja nagrań rozmów (OpenAI Whisper) — po nagraniu z Twilio
# OPENAI_API_KEY=

# W dev można wyłączyć weryfikację podpisu Twilio na webhooku nagrania (nie w produkcji)
# TWILIO_SKIP_SIGNATURE_VALIDATION=false

# Archiwum pliku nagrania po pobraniu z Twilio: local (domyślnie, katalog private/), s3, gdrive, none
# PHONE_RECORDING_STORAGE=local
# Niestandardowy katalog (domyślnie <repo>/private/phone-recordings)
# PHONE_RECORDINGS_DIR=
# --- S3 / R2 (gdy PHONE_RECORDING_STORAGE=s3) ---
# S3_BUCKET=
# S3_REGION=auto
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=
# S3_PUBLIC_BASE_URL=
# S3_FORCE_PATH_STYLE=false
# --- Google Drive (gdy PHONE_RECORDING_STORAGE=gdrive) — JSON konta serwisowego w jednej linii ---
# GOOGLE_SERVICE_ACCOUNT_JSON=
# GOOGLE_DRIVE_FOLDER_ID=

# --- SMTP / raporty dzienne (opcjonalnie) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# --- Anthropic AI (opcjonalnie) ---
ANTHROPIC_API_KEY=

# --- Limity kosztownych endpointów (AI / SMS / PDF) ---
# Okno w ms i max żądań na IP w oknie (domyślnie 60000 / 40)
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=40

# --- Metryki Prometheus (/api/metrics); w produkcji ustaw true tylko jeśli chronisz endpoint ---
METRICS_ENABLED=false

# --- Webhook (opcjonalnie): POST JSON po wysłaniu raportu dziennego e-mailem ---
# WEBHOOK_URL=https://twoj-system.example/hooks/arbor
