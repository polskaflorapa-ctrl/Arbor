# --- Serwer ---
NODE_ENV=development
PORT=3000

# JWT (w produkcji obowiązkowy, silny)
JWT_SECRET=

# --- Baza (jedna z dwóch opcji) ---
# Render: wklej Internal Database URL z panelu Postgres (baza logiczna z render.yaml to arbor_db). Nie wgrywaj .env z lokalną nazwą bazy, jeśli inna niż na Renderze.
# DATABASE_URL=postgres://user:haslo@localhost:5432/arbor
DB_HOST=localhost
DB_PORT=5432
# Lokalnie z docker-compose.yml (npm run db:up): baza arbor_dev, hasło postgres
DB_NAME=arbor_dev
DB_USER=postgres
DB_PASSWORD=postgres

# Przykładowe zlecenia: najpierw npm run db:up (Docker), potem npm run seed:demo-full (migrate + smoke:user + seed:demo-tasks). Tylko seed: npm run seed:demo-tasks. SEED_DEMO_REPLACE=1 — nadpisanie wierszy demo.

# --- CORS (opcjonalnie, lista po przecinku; * = dowolny origin) ---
# CORS_ORIGINS=http://localhost:5173,https://app.example.com

# --- Twilio SMS (opcjonalnie) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=

# Publiczny adres API (HTTPS), np. https://twoja-domena.pl lub tunel ngrok — wymagany do połączeń głosowych Twilio (TwiML)
# PUBLIC_BASE_URL=https://twoj-serwer.example

# Lead „Do wyceny” z Kommo → POST /api/webhooks/kommo/quotation-lead (nagłówek X-Arbor-Webhook-Secret lub body.secret)
# KOMMO_QUOTATION_WEBHOOK_SECRET=

# Prowizja od „Przelew” w matrycy płatności M11 / F11.3 (np. 1.5 = odjęcie 1,5% od brutto)
# PAYROLL_CARD_COMMISSION_PCT=1.5
# PAYROLL_OVERTIME_MULT=1.5
# Pora nocna (Europe/Warsaw): okna [D−1 22:00, D 06:00) ∪ [D 22:00, D+1 06:00) — godziny × night_multiplier z user_payroll_rates
# PAYROLL_NIGHT_START_HOUR=22
# PAYROLL_NIGHT_END_HOUR=6
# PAYROLL_EXPORT_SKIP_APPROVAL_CHECK=1
# F11.2 — zapis snapshotu linii do tabeli daily_payroll przy eksporcie CSV/ZIP; wyłączenie = 0
# PAYROLL_EXPORT_SNAPSHOT=0
# F11.7 — HMAC manifestu w ZIP (payroll_*_manifest.json); weryfikacja: HMAC-SHA256(secret, JSON bez pola hmac_sha256)
# PAYROLL_ZIP_MANIFEST_HMAC_SECRET=
# Hasło archiwum ZIP (AES-256 domyślnie); puste = ZIP bez szyfrowania. Otwarcie AES: 7-Zip / WinZip (Explorer Windows nie dekryptuje treści).
# PAYROLL_ZIP_PASSWORD=
# Słabsza kompatybilność ze starym unzip (Zip 2.0 / ZipCrypto) — niezalecane: PAYROLL_ZIP_ENCRYPTION_METHOD=zip20
# Push Expo po zatwierdzeniu raportu dnia (F11.8); wyłączenie: PAYROLL_PUSH_ENABLED=0
# PAYROLL_PUSH_ENABLED=1
# Opcjonalnie Bearer dla https://exp.host/--/api/v2/push/send (wyższe limity w Expo)
# EXPO_ACCESS_TOKEN=
# Opcjonalnie: limit ponownego przeliczenia raportu dnia (godziny od pierwszego zamknięcia); puste = tylko blokada po zatwierdzeniu
# PAYROLL_TEAM_DAY_CORRECTION_HOURS=24

# Cron SLA wycen: GET /api/ops/quotation-sla-tick?secret=...
# Wygaśnięcie ofert (Wyslana_Klientowi → Wygasla): GET /api/ops/quotation-expiry-tick?secret=... (ten sam OPS_CRON_SECRET)
# Przypomnienia o nieodebranej kasie (F11.5): GET /api/ops/payroll-cash-reminder-tick?secret=...
# Dodatkowo SMS (Twilio jak przy zleceniach) do kierowników/dyrekcji — domyślnie wyłączone
# PAYROLL_CASH_REMINDER_SMS=1
# F11.5 — e-mail (SMTP_USER/SMTP_PASS) do tych samych odbiorców co in-app; domyślnie wyłączone
# PAYROLL_CASH_REMINDER_EMAIL=1
# OPS_CRON_SECRET=

# Transkrypcja nagrań rozmów (OpenAI Whisper) — po nagraniu z Twilio
# OPENAI_API_KEY=

# W dev można wyłączyć weryfikację podpisu Twilio na webhooku nagrania (nie w produkcji)
# TWILIO_SKIP_SIGNATURE_VALIDATION=false

# Archiwum pliku nagrania po pobraniu z Twilio: local (domyślnie, katalog private/), s3, gdrive, none
# PHONE_RECORDING_STORAGE=local
# Niestandardowy katalog (domyślnie <repo>/private/phone-recordings)
# PHONE_RECORDINGS_DIR=
# --- S3 / R2 (gdy PHONE_RECORDING_STORAGE=s3) ---
# S3_BUCKET=
# S3_REGION=auto
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=
# S3_PUBLIC_BASE_URL=
# S3_FORCE_PATH_STYLE=false
# --- Google Drive (gdy PHONE_RECORDING_STORAGE=gdrive) — JSON konta serwisowego w jednej linii ---
# GOOGLE_SERVICE_ACCOUNT_JSON=
# GOOGLE_DRIVE_FOLDER_ID=

# --- SMTP / raporty dzienne (opcjonalnie) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# --- Anthropic AI (opcjonalnie) ---
ANTHROPIC_API_KEY=

# --- Limity kosztownych endpointów (AI / SMS / PDF) ---
# Okno w ms i max żądań na IP w oknie (domyślnie 60000 / 40)
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=40

# --- Metryki Prometheus (/api/metrics); w produkcji ustaw true tylko jeśli chronisz endpoint ---
METRICS_ENABLED=false

# --- Webhook (opcjonalnie): POST JSON po wysłaniu raportu dziennego e-mailem ---
# WEBHOOK_URL=https://twoj-system.example/hooks/arbor

# --- Kommo CRM (opcjonalnie) — te same zmienne co web/server; szczegóły: web/docs/kommo-wlasna-instancja.md ---
# KOMMO_WEBHOOK_URL=https://hook.make.com/...
# KOMMO_CRM_WEBHOOK_URL=   # opcjonalnie osobny URL dla zleceń + klientów (CMR zostaje na KOMMO_WEBHOOK_URL)
# KOMMO_PIPELINE_ID= KOMMO_STATUS_ID= KOMMO_RESPONSIBLE_USER_ID=
# KOMMO_CRM_TAGS=Arbor,CRM
# KOMMO_CF_ORDER_ID= KOMMO_CF_BRANCH_ID= KOMMO_CF_STATUS_ID= KOMMO_CF_LOAD_DATE_ID= KOMMO_CF_PHONE_ID= KOMMO_CF_GOODS_SUMMARY_ID= KOMMO_CF_KLIENT_RECORD_ID=
# KOMMO_WEBHOOK_SECRET_HEADER= KOMMO_WEBHOOK_SECRET=

# --- Smoke / dev (skrypty `npm run smoke:user`, `npm run smoke:f03`) ---
# DB_* jak wyżej. `smoke:user` tworzy `smoke_admin` i `smoke_brygadzista` (hasło domyślnie Smoke123!); inne hasło seedu ekipy:
# SMOKE_TEAM_PASSWORD_SEED=TwojeHaslo

# --- M3 F3.5–F3.7 (finish ekipy) ---
# Wymuś co najmniej jedno zdjęcie typu „Po” przed POST /tasks/:id/finish (ekipa): TASK_FINISH_REQUIRE_PO_PHOTO=1
# Opcjonalnie: wymóg zdjęcia „Przed” lub check-in: TASK_FINISH_REQUIRE_PRZED_PHOTO=1
# Opcjonalnie: wymóg tablicy zuzyte_materialy przy finish: TASK_FINISH_REQUIRE_MATERIAL_USAGE=1

# --- Juwentus GPS (opcjonalnie) ---
# Endpoint API zwracający aktualne pozycje pojazdów (JSON)
# JUWENTUS_GPS_API_URL=https://api.juwentus.example/v1/vehicles/positions
# Token Bearer do API Juwentus
# JUWENTUS_GPS_API_TOKEN=
