EXPO_PUBLIC_API_URL=https://arbor-os-dvf7.onrender.com

# Gdy panel web (React) jest na innym hoście niż API bez /api — linki „CMR w przeglądarce” z aplikacji mobilnej
# EXPO_PUBLIC_WEB_APP_URL=https://twoj-frontend.example.com

# Opcjonalnie: wersja API — ostrzeżenie w diagnostyce, gdy nagłówek X-Api-Version się różni
# EXPO_PUBLIC_EXPECTED_API_VERSION=1.0.0

# Backend: GET {API_URL}/mobile-config (JSON: oddzialFeatureOverrides | overrides | oddzialy)
# Szablon: config/mobile-config.example.json

# F11.8 — push po zatwierdzeniu raportu dnia: token zapisuje się na serwerze po zalogowaniu (jeśli są już granted permissions)
# lub po „Pobierz token” na ekranie Powiadomienia. Na serwerze OS: migracja user_expo_push_tokens; opcj. EXPO_ACCESS_TOKEN w .env OS.
