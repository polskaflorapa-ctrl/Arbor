# Expo public environment. Copy to `mobile/.env`.
# For a physical phone on local Wi-Fi, use the computer LAN IP instead of localhost.

EXPO_PUBLIC_API_URL=https://api.twoja-domena.pl/api
EXPO_PUBLIC_WEB_APP_URL=https://app.twoja-domena.pl
EXPO_PUBLIC_EXPECTED_API_VERSION=1.0.0

# Backend remote config:
# GET {EXPO_PUBLIC_API_URL}/mobile-config
#
# Push notifications:
# OS backend stores Expo push tokens after login. Optional server-side higher
# limits use EXPO_ACCESS_TOKEN in os/.env.
