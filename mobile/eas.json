{
  "cli": {
    "version": ">= 19.1.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://arbor-os-b7k6.onrender.com/api",
        "EXPO_PUBLIC_EXPECTED_API_VERSION": "mobile-dev"
      },
      "ios": {
        "simulator": false
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://arbor-os-b7k6.onrender.com/api",
        "EXPO_PUBLIC_EXPECTED_API_VERSION": "mobile-preview"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://arbor-os-b7k6.onrender.com/api",
        "EXPO_PUBLIC_EXPECTED_API_VERSION": "mobile-production"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
