{
  "expo": {
    "name": "arbor-mobile",
    "owner": "arboros",
    "slug": "arbor-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "arbormobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "buildNumber": "1",
      "bundleIdentifier": "com.arbor.mobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.arbor.mobile",
      "versionCode": 1,
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "backgroundColor": "#060908",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "ARBOR-OS uzywa aparatu do dokumentowania zlecen, ogledzin, protokolow i zdjec przed oraz po pracy."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "ARBOR-OS potrzebuje dostepu do zdjec, aby dolaczac dokumentacje terenu, szkice i materialy do zlecen."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "ARBOR-OS uzywa Face ID do odblokowania aplikacji po wlaczeniu blokady prywatnosci."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#ffffff"
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "disableAutoUpload": true
        }
      ],
      "./plugins/with-react-native-node-modules-dir.cjs",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "ARBOR-OS uzywa lokalizacji w czasie pracy, aby pokazac pozycje brygad i wyceniajacych w harmonogramie."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#eef2f6",
          "dark": {
            "backgroundColor": "#060908"
          }
        }
      ],
      "expo-secure-store",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "57fa709a-200c-46fb-a2dc-208bd78a7103"
      }
    }
  }
}
