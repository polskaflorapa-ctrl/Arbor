{
  "expo": {
    "name": "Polska Flora",
    "owner": "arboros",
    "slug": "arbor-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/brand/app-icons/app-icon.png",
    "scheme": "arbormobile",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "buildNumber": "1",
      "bundleIdentifier": "com.arbor.mobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.arbor.mobile",
      "versionCode": 1,
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "backgroundColor": "#3B2A18",
        "foregroundImage": "./assets/brand/app-icons/adaptive-foreground.png",
        "backgroundImage": "./assets/brand/app-icons/adaptive-background.png",
        "monochromeImage": "./assets/brand/app-icons/adaptive-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/brand/app-icons/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "ARBOR-OS uzywa aparatu do dokumentowania zlecen, ogledzin, protokolow i zdjec przed oraz po pracy."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "ARBOR-OS potrzebuje dostepu do zdjec, aby dolaczac dokumentacje terenu, szkice i materialy do zlecen."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "ARBOR-OS uzywa Face ID do odblokowania aplikacji po wlaczeniu blokady prywatnosci."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/brand/app-icons/notification-icon.png",
          "color": "#A0AF14"
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "disableAutoUpload": true
        }
      ],
      "./plugins/with-react-native-node-modules-dir.cjs",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "ARBOR-OS uzywa lokalizacji w czasie pracy, aby pokazac pozycje brygad i wyceniajacych w harmonogramie."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/brand/logos/with-descriptor/png/horizontal-light.png",
          "imageWidth": 280,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF",
          "dark": {
            "image": "./assets/brand/logos/with-descriptor/png/horizontal-dark.png",
            "backgroundColor": "#3B2A18"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/brand/fonts/RoadUA-Black.otf",
            "./assets/brand/fonts/RoadUA-Bold.otf",
            "./assets/brand/fonts/RoadUA-ExtraBold.otf",
            "./assets/brand/fonts/RoadUA-ExtraLight.otf",
            "./assets/brand/fonts/RoadUA-Light.otf",
            "./assets/brand/fonts/RoadUA-Medium.otf",
            "./assets/brand/fonts/RoadUA-Regular.otf",
            "./assets/brand/fonts/RoadUA-Thin.otf"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "57fa709a-200c-46fb-a2dc-208bd78a7103"
      }
    }
  }
}
