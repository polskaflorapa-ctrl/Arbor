{
  "name": "arbor-mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "postinstall": "node ./scripts/postinstall-patches.cjs",
    "patch:native": "node ./scripts/postinstall-patches.cjs",
    "codex:run": "node ./script/build_and_run.cjs",
    "codex:android": "node ./script/build_and_run.cjs --android",
    "codex:ios": "node ./script/build_and_run.cjs --ios",
    "codex:web": "node ./script/build_and_run.cjs --web",
    "codex:doctor": "node ./script/build_and_run.cjs --doctor",
    "start": "expo start",
    "start:clear": "expo start --clear",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "node ./scripts/run-expo-lint.cjs",
    "typecheck": "node ./scripts/run-tsc-noemit.cjs",
    "test:module-resolution": "node ./scripts/check-module-resolution.cjs",
    "test:offline-queue": "node ./scripts/test-offline-queue.cjs",
    "test:notification-deeplink": "node ./scripts/test-notification-deeplink.cjs",
    "test:app-error-report": "node ./scripts/test-app-error-report.cjs",
    "test:error-monitoring": "node ./scripts/test-error-monitoring.cjs",
    "test:release-qa-status": "node ./scripts/test-release-qa-status.cjs",
    "test:device-qa-note": "node ./scripts/test-device-qa-note.cjs",
    "test:zlecenie-detail": "node ./scripts/test-zlecenie-detail.cjs",
    "test:metro-bundle": "node ./scripts/check-metro-bundle.cjs",
    "smoke:mobile": "node ./scripts/smoke-mobile-release.cjs",
    "release:check:quick": "node -e \"process.env.SKIP_METRO_BUNDLE='1'; require('./scripts/check-mobile-release-ready.cjs')\"",
    "release:check": "node ./scripts/check-mobile-release-ready.cjs",
    "release:status": "node ./scripts/mobile-release-status.cjs",
    "audit:functional": "node ./scripts/mobile-functional-audit.cjs",
    "qa:note": "node ./scripts/create-device-qa-note.cjs",
    "qa:validate": "node ./scripts/validate-device-qa-note.cjs",
    "qa:review": "node ./scripts/review-device-qa-notes.cjs",
    "release:eas-doctor": "node ./scripts/eas-release-doctor.cjs",
    "release:ios:preflight": "node ./scripts/ios-credentials-helper.cjs check",
    "release:ios:credentials": "node ./scripts/ios-credentials-helper.cjs credentials",
    "install:android:preview": "node ./scripts/install-android-preview.cjs",
    "release:build:ios:preview": "node ./scripts/eas-release-build.cjs ios preview",
    "release:build:ios:production": "node ./scripts/eas-release-build.cjs ios production",
    "release:build:android:preview": "node ./scripts/eas-release-build.cjs android preview",
    "release:build:android:production": "node ./scripts/eas-release-build.cjs android production",
    "smoke:api": "node ./scripts/smoke-api-rezerwacje.cjs"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-picker/picker": "2.11.4",
    "@sentry/react-native": "^8.13.0",
    "@types/lodash": "^4.17.24",
    "expo": "56.0.9",
    "expo-camera": "~56.0.7",
    "expo-clipboard": "~56.0.4",
    "expo-constants": "~56.0.17",
    "expo-device": "~56.0.4",
    "expo-font": "~56.0.5",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.10",
    "expo-image-picker": "~56.0.16",
    "expo-linking": "~56.0.13",
    "expo-local-authentication": "~56.0.4",
    "expo-location": "~56.0.16",
    "expo-network": "~56.0.5",
    "expo-notifications": "~56.0.16",
    "expo-router": "~56.2.9",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.6",
    "expo-system-ui": "~56.0.5",
    "expo-web-browser": "~56.0.5",
    "lodash": "^4.17.21",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-calendars": "^1.1314.0",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-view-shot": "5.1.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@types/react": "~19.2.14",
    "babel-preset-expo": "~56.0.0",
    "css-in-js-utils": "^3.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~56.0.4",
    "typescript": "~6.0.3"
  },
  "private": true,
  "expo": {
    "install": {
      "exclude": [
        "@sentry/react-native"
      ]
    }
  }
}
