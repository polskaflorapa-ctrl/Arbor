{
  "name": "arbor-mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "postinstall": "node ./scripts/postinstall-patches.cjs",
    "patch:native": "node ./scripts/postinstall-patches.cjs",
    "start": "expo start",
    "start:clear": "expo start --clear",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "node ./scripts/run-expo-lint.cjs",
    "typecheck": "node ./scripts/run-tsc-noemit.cjs",
    "test:module-resolution": "node ./scripts/check-module-resolution.cjs",
    "test:offline-queue": "node ./scripts/test-offline-queue.cjs",
    "test:notification-deeplink": "node ./scripts/test-notification-deeplink.cjs",
    "test:app-error-report": "node ./scripts/test-app-error-report.cjs",
    "test:error-monitoring": "node ./scripts/test-error-monitoring.cjs",
    "test:release-qa-status": "node ./scripts/test-release-qa-status.cjs",
    "test:metro-bundle": "node ./scripts/check-metro-bundle.cjs",
    "smoke:mobile": "node ./scripts/smoke-mobile-release.cjs",
    "release:check:quick": "node -e \"process.env.SKIP_METRO_BUNDLE='1'; require('./scripts/check-mobile-release-ready.cjs')\"",
    "release:check": "node ./scripts/check-mobile-release-ready.cjs",
    "release:eas-doctor": "node ./scripts/eas-release-doctor.cjs",
    "release:build:ios:preview": "node ./scripts/eas-release-build.cjs ios preview",
    "release:build:ios:production": "node ./scripts/eas-release-build.cjs ios production",
    "release:build:android:preview": "node ./scripts/eas-release-build.cjs android preview",
    "release:build:android:production": "node ./scripts/eas-release-build.cjs android production",
    "smoke:api": "node ./scripts/smoke-api-rezerwacje.cjs"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-picker/picker": "^2.11.1",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/stack": "^7.9.3",
    "@sentry/react-native": "^8.13.0",
    "@types/lodash": "^4.17.24",
    "expo": "~54.0.35",
    "expo-camera": "~17.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
    "expo-font": "~14.0.12",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.11",
    "expo-linking": "~8.0.12",
    "expo-local-authentication": "~17.0.8",
    "expo-location": "~19.0.8",
    "expo-network": "~8.0.8",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.11",
    "lodash": "^4.17.21",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-calendars": "^1.1314.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-view-shot": "4.0.3",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "babel-preset-expo": "~54.0.11",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "typescript": "~5.9.2"
  },
  "private": true,
  "expo": {
    "install": {
      "exclude": [
        "react-native",
        "@react-navigation/native"
      ]
    }
  }
}
