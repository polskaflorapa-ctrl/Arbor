{
  "name": "arbor",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "mobile",
    "web",
    "os"
  ],
  "scripts": {
    "postinstall": "node ./mobile/scripts/postinstall-patches.cjs",
    "mobile": "cd mobile && npm run start",
    "web": "npm run start -w arbor-web",
    "build": "npm run build -w arbor-web && node ./scripts/sync-web-build.cjs",
    "os": "npm run dev -w arbor-os",
    "os:stack": "npm run dev:stack -w arbor-os",
    "api": "npm run server -w arbor-web",
    "api:dev": "npm run server:dev -w arbor-web",
    "dev:web": "npm run web",
    "dev:mobile": "npm run mobile",
    "dev:os": "npm run os",
    "dev:api": "npm run api",
    "dev": "node ./scripts/dev-smart.cjs",
    "dev:all": "npx --yes concurrently -n API,WEB,OS \"npm run dev:api\" \"npm run dev:web\" \"npm run dev:os\"",
    "health": "node ./scripts/health-check.cjs",
    "status": "node ./scripts/status.cjs",
    "status:web": "npm run status:web -w arbor-web",
    "status:web:json": "npm run status:web:json -w arbor-web",
    "status:json": "node ./scripts/status.cjs --json",
    "status:json:strict": "node ./scripts/status.cjs --json --strict",
    "ci:check": "node ./scripts/ci-check.cjs",
    "verify:mobile": "npm run typecheck -w arbor-mobile && npm run lint -w arbor-mobile",
    "verify:web:test": "npm test -w arbor-web -- --watchAll=false",
    "verify:web": "npm run build -w arbor-web",
    "verify:os": "npm run lint -w arbor-os",
    "verify:os:test": "npm test -w arbor-os",
    "verify:os:full": "npm run verify:os && npm run verify:os:test",
    "verify:static": "npm run verify:mobile && npm run verify:web:test && npm run verify:web && npm run verify:os",
    "verify:static:parallel": "concurrently -n mobile,web,os -c auto \"npm run verify:mobile\" \"npm run verify:web:test && npm run verify:web\" \"npm run verify:os\"",
    "check": "npm run verify:static",
    "check:full": "npm run verify:mobile && npm run verify:web:test && npm run verify:web && npm run verify:os:full",
    "check:parallel": "npm run verify:static:parallel",
    "check:mobile": "npm run verify:mobile",
    "check:web": "npm run verify:web:test && npm run verify:web",
    "check:os": "npm run verify:os",
    "doctor": "node ./scripts/doctor.cjs",
    "deploy:env:print": "node ./scripts/print-production-env-template.cjs",
    "deploy:ready:check": "node ./scripts/deploy-ready-check.cjs",
    "deploy:netlify:check": "node ./scripts/deploy-netlify-check.cjs",
    "deploy:koyeb:check": "node ./scripts/deploy-koyeb-check.cjs",
    "deploy:free:check": "node ./scripts/deploy-free-preflight.cjs",
    "deploy:demo:check": "node ./scripts/demo-deploy-check.cjs",
    "deploy:pages:cloudflare": "node ./scripts/deploy-cloudflare-pages.cjs",
    "bootstrap:admin": "npm run bootstrap:admin -w arbor-os",
    "deploy:prod:doctor": "npm run prod:doctor -w arbor-os --",
    "deploy:prod:bootstrap": "node ./scripts/run-production-bootstrap.cjs",
    "start:api:prod": "node ./scripts/start-api-with-migrations.cjs",
    "seed:president-demo": "npm run seed:president-demo -w arbor-os",
    "smoke:operational": "npm run smoke:operational -w arbor-os",
    "backup:db": "npm run backup:db -w arbor-os",
    "backup:db:check": "npm run backup:db:check -w arbor-os",
    "restore:db": "npm run restore:db -w arbor-os --",
    "restore:db:check": "npm run restore:db:check -w arbor-os --",
    "smoke:render": "node ./os/scripts/smoke-production-check.js",
    "up": "node ./scripts/up.cjs",
    "up:force": "node ./scripts/up.cjs --force",
    "down": "node ./scripts/down.cjs",
    "restart:force": "node ./scripts/restart-force.cjs"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "react-native": "0.81.5"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "@expo/vector-icons": {
      "react-native": "0.81.5"
    }
  },
  "dependencies": {
    "@netlify/database": "^1.0.0",
    "serverless-http": "^4.0.0"
  }
}
