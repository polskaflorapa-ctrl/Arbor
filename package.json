{
  "name": "arbor",
  "private": true,
  "engines": {
    "node": ">=22.12.0"
  },
  "workspaces": [
    "mobile",
    "web",
    "os"
  ],
  "scripts": {
    "postinstall": "node ./mobile/scripts/postinstall-patches.cjs",
    "mobile": "cd mobile && npm run start",
    "web": "npm run start -w arbor-web",
    "build": "npm run build -w arbor-web && node ./scripts/sync-web-build.cjs",
    "os": "npm run dev -w arbor-os",
    "os:stack": "npm run dev:stack -w arbor-os",
    "api": "npm run server -w arbor-web",
    "api:dev": "npm run server:dev -w arbor-web",
    "dev:web": "npm run web",
    "dev:mobile": "npm run mobile",
    "dev:os": "npm run os",
    "dev:api": "npm run api",
    "dev": "node ./scripts/dev-smart.cjs",
    "dev:all": "npx --yes concurrently -n API,WEB,OS \"npm run dev:api\" \"npm run dev:web\" \"npm run dev:os\"",
    "health": "node ./scripts/health-check.cjs",
    "test:scripts": "node --test scripts/*.test.cjs",
    "status": "node ./scripts/status.cjs",
    "status:web": "npm run status:web -w arbor-web",
    "status:web:json": "npm run status:web:json -w arbor-web",
    "status:json": "node ./scripts/status.cjs --json",
    "status:json:strict": "node ./scripts/status.cjs --json --strict",
    "ci:check": "node ./scripts/ci-check.cjs",
    "circleci:trigger": "node ./scripts/circleci-trigger-pipeline.cjs",
    "verify:circleci": "node ./scripts/circleci-config-check.cjs",
    "verify:scripts": "npm run test:scripts && npm run verify:circleci",
    "verify:mobile": "npm run typecheck -w arbor-mobile && npm run lint -w arbor-mobile",
    "verify:web:test": "npm test -w arbor-web",
    "verify:web": "npm run build -w arbor-web",
    "verify:os": "npm run lint -w arbor-os",
    "verify:os:test": "npm test -w arbor-os",
    "verify:os:full": "npm run verify:os && npm run verify:os:test",
    "verify:api-routes": "npm run verify:routes:auth -w arbor-os",
    "verify:static": "npm run verify:scripts && npm run verify:mobile && npm run verify:web:test && npm run verify:web && npm run verify:os",
    "verify:static:parallel": "concurrently -n scripts,mobile,web,os -c auto \"npm run verify:scripts\" \"npm run verify:mobile\" \"npm run verify:web:test && npm run verify:web\" \"npm run verify:os\"",
    "check": "npm run verify:static",
    "check:full": "npm run verify:scripts && npm run verify:mobile && npm run verify:web:test && npm run verify:web && npm run verify:os:full",
    "check:parallel": "npm run verify:static:parallel",
    "check:mobile": "npm run verify:mobile",
    "check:web": "npm run verify:web:test && npm run verify:web",
    "check:os": "npm run verify:os",
    "doctor": "node ./scripts/doctor.cjs",
    "verify:env-runbook": "node ./scripts/env-runbook-check.cjs",
    "verify:pilot-hardening": "node ./scripts/pilot-hardening-check.cjs",
    "verify:observability": "node ./scripts/observability-check.cjs",
    "verify:incident-runbook": "node ./scripts/incident-runbook-check.cjs",
    "verify:kommo-sms-drill": "node ./scripts/kommo-sms-drill-check.cjs",
    "verify:backup-rpo": "node ./scripts/backup-rpo-check.cjs",
    "verify:web-tti": "node ./scripts/web-tti-check.cjs",
    "verify:scale-readiness": "node ./scripts/scale-readiness-check.cjs",
    "verify:rbac-scope": "node ./scripts/rbac-scope-check.cjs",
    "verify:dispatcher-adr": "node ./scripts/dispatcher-adr-check.cjs",
    "verify:mobile-problem-flow": "node ./scripts/mobile-problem-flow-check.cjs",
    "verify:mobile-before-after-photo": "node ./scripts/mobile-before-after-photo-check.cjs",
    "verify:mobile-photo-enforcement": "node ./scripts/mobile-photo-enforcement-check.cjs",
    "verify:mobile-material-cost-flow": "node ./scripts/mobile-material-cost-flow-check.cjs",
    "verify:mobile-today-cache": "node ./scripts/mobile-today-cache-check.cjs",
    "verify:mobile-offline-conflicts": "node ./scripts/mobile-offline-conflict-check.cjs",
    "verify:mobile-start-stop-edge": "node ./scripts/mobile-start-stop-edge-check.cjs",
    "verify:resource-calendar-week": "node ./scripts/resource-calendar-week-check.cjs",
    "verify:resource-calendar-dnd": "node ./scripts/resource-calendar-dnd-check.cjs",
    "verify:planning-map": "node ./scripts/planning-map-check.cjs",
    "verify:equipment-cards": "node ./scripts/equipment-cards-check.cjs",
    "verify:fleet-repair-due-controls": "node ./scripts/fleet-repair-due-controls-check.cjs",
    "verify:dispatcher-day-plan": "node ./scripts/dispatcher-day-plan-check.cjs",
    "verify:machine-cards-crud": "node ./scripts/machine-cards-crud-check.cjs",
    "verify:equipment-usage-rules": "node ./scripts/equipment-usage-rules-check.cjs",
    "verify:warehouse-materials": "node ./scripts/warehouse-materials-check.cjs",
    "verify:warehouse-mobile-usage": "node ./scripts/warehouse-mobile-usage-check.cjs",
    "verify:worklog-timesheet": "node ./scripts/worklog-timesheet-check.cjs",
    "verify:competency-expiry-monitoring": "node ./scripts/competency-expiry-monitoring-check.cjs",
    "verify:team-competency-assignment-block": "node ./scripts/team-competency-assignment-block-check.cjs",
    "verify:dispatcher-competency-consistency": "node ./scripts/dispatcher-competency-consistency-check.cjs",
    "verify:kommo-idempotency-retry": "node ./scripts/kommo-idempotency-retry-check.cjs",
    "verify:ops-alert-ownership": "node ./scripts/ops-alert-ownership-check.cjs",
    "verify:ops-alert-owner-ui": "node ./scripts/ops-alert-owner-ui-check.cjs",
    "verify:ops-owner-control": "node ./scripts/ops-owner-control-check.cjs",
    "verify:ops-owner-remediation-closure": "node ./scripts/ops-owner-remediation-closure-check.cjs",
    "deploy:env:print": "node ./scripts/print-production-env-template.cjs",
    "prod:ready": "node ./scripts/production-readiness.cjs",
    "deploy:prod:dry-run": "node ./scripts/production-dry-run-check.cjs",
    "deploy:ready:check": "node ./scripts/deploy-ready-check.cjs",
    "deploy:vercel:check": "node ./scripts/deploy-vercel-check.cjs",
    "deploy:vercel": "node ./scripts/deploy-vercel-prod.cjs",
    "deploy:vercel:migrate": "npm run db:migrate -w arbor-os",
    "deploy:vercel:smoke": "node ./scripts/deploy-vercel-smoke.cjs",
    "deploy:netlify:check": "node ./scripts/deploy-netlify-check.cjs",
    "deploy:koyeb:check": "node ./scripts/deploy-koyeb-check.cjs",
    "deploy:free:check": "node ./scripts/deploy-free-preflight.cjs",
    "deploy:demo:check": "node ./scripts/demo-deploy-check.cjs",
    "deploy:pages:cloudflare": "node ./scripts/deploy-cloudflare-pages.cjs",
    "bootstrap:admin": "npm run bootstrap:admin -w arbor-os",
    "deploy:prod:doctor": "npm run prod:doctor -w arbor-os --",
    "deploy:prod:bootstrap": "node ./scripts/run-production-bootstrap.cjs",
    "start:api:prod": "node ./scripts/start-api-with-migrations.cjs",
    "seed:president-demo": "npm run seed:president-demo -w arbor-os",
    "smoke:operational": "npm run smoke:operational -w arbor-os",
    "smoke:critical-path": "npm run test:critical-path -w arbor-os",
    "smoke:demo:e2e": "npm run smoke:critical-path && npm run smoke:demo:e2e -w arbor-web",
    "smoke:p95": "node ./os/scripts/smoke-p95-check.js",
    "smoke:web:tti": "npm run smoke:tti -w arbor-web --",
    "backup:db": "npm run backup:db -w arbor-os",
    "backup:db:check": "npm run backup:db:check -w arbor-os",
    "restore:db": "npm run restore:db -w arbor-os --",
    "restore:db:check": "npm run restore:db:check -w arbor-os --",
    "smoke:render": "node ./os/scripts/smoke-production-check.js",
    "up": "node ./scripts/up.cjs",
    "up:force": "node ./scripts/up.cjs --force",
    "down": "node ./scripts/down.cjs",
    "restart:force": "node ./scripts/restart-force.cjs"
  },
  "devDependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@types/react": "19.2.14",
    "concurrently": "^9.2.1",
    "expo-router": "~56.2.9",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "uuid": "^11.1.1",
    "yaml": "^2.9.0"
  },
  "overrides": {
    "react-native": "0.85.3",
    "minimatch@10": {
      "brace-expansion": "5.0.6"
    },
    "@expo/metro-config@56.0.13": {
      "postcss": "8.5.15"
    },
    "xcode@3.0.1": {
      ".": "3.0.1",
      "uuid": "11.1.1"
    },
    "@expo/vector-icons": {
      "react-native": "0.85.3"
    }
  },
  "dependencies": {
    "@netlify/database": "^1.0.0",
    "serverless-http": "^4.0.0"
  }
}
