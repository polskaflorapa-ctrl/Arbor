# Vercel project environment variables
#
# The web app is deployed as a Vite static app and `/api/*` is served by
# `api/[...path].js`, which wraps the Arbor OS Express backend.

NODE_ENV=production
JWT_SECRET=<strong-random-secret>
DATABASE_URL=<postgres-connection-string>

# Optional: runs os/migrate.sql once per cold-start container before creating the API app.
# Recommended default is 0; run migrations as a separate deploy step when possible.
VERCEL_RUN_MIGRATIONS=0

# Public URL of this Vercel project, without a trailing slash.
# Required for links generated by telephony, SMS, PDFs, and public quotation flows.
PUBLIC_BASE_URL=https://<your-vercel-project>.vercel.app

# Restrict after the final domain is known. Use a comma-separated list for multiple domains.
CORS_ORIGINS=https://<your-vercel-project>.vercel.app

# Vercel functions only have ephemeral local disk. Use S3/R2 for real production uploads.
UPLOAD_STORAGE=s3
S3_BUCKET=<bucket>
S3_REGION=<region>
S3_ACCESS_KEY_ID=<access-key>
S3_SECRET_ACCESS_KEY=<secret-key>
S3_PUBLIC_BASE_URL=<optional-public-base-url>

# Optional integrations
OPS_CRON_SECRET=<strong-random-secret>
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=
ZADARMA_API_KEY=
ZADARMA_API_SECRET=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
