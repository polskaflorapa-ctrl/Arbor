# Koyeb environment variables for ARBOR-OS demo API.
# Create a Web Service from the os/ work directory or deploy os/ with the CLI.
# Do not commit real secrets.

NODE_ENV=production
PORT=3000
TRUST_PROXY=1

# Neon Free pooled connection string. Use the host with "-pooler".
DATABASE_URL=postgresql://<user>:<password>@<neon-pooler-host>/<db>?sslmode=require
DB_POOL_MAX=5
DB_CONNECT_TIMEOUT_MS=10000
DB_IDLE_TIMEOUT_MS=10000

# Use memory for single-instance deploys, or redis for shared login limits.
LOGIN_RATE_LIMIT_STORE=memory
# LOGIN_RATE_LIMIT_STORE=redis
# LOGIN_RATE_LIMIT_REDIS_URL=redis://<user>:<password>@<redis-host>:6379

JWT_SECRET=<long-random-secret>

# Exact deployed web URL. Add more origins separated by commas when needed.
CORS_ORIGINS=https://<arbor-web>.netlify.app

# Optional: env.js can infer this from KOYEB_PUBLIC_DOMAIN, but setting it
# explicitly is clearer for Twilio/public quotation links.
PUBLIC_BASE_URL=https://<arbor-os>.koyeb.app

# Durable photos/PDFs for demo. Keep local only for smoke tests.
UPLOAD_STORAGE=s3
S3_BUCKET=<bucket-name>
S3_REGION=auto
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=<access-key-id>
S3_SECRET_ACCESS_KEY=<secret-access-key>
S3_PUBLIC_BASE_URL=https://<public-bucket-or-custom-domain>
S3_UPLOAD_PREFIX=uploads/demo
S3_FORCE_PATH_STYLE=true

METRICS_ENABLED=false
PHONE_RECORDING_STORAGE=none

# Zadarma is the primary SMS/telephony provider for this project.
ZADARMA_API_KEY=
ZADARMA_API_SECRET=
ZADARMA_CALLER_ID=ARBOR
