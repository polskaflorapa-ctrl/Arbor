# ARBOR-OS Render environment template
# Paste into Render -> arbor-os -> Environment.
# Do not commit real secrets.

NODE_ENV=production
TRUST_PROXY=1

# Neon Free pooled connection string. Use host with "-pooler".
DATABASE_URL=postgresql://<user>:<password>@<neon-pooler-host>/<db>?sslmode=require

# Render Blueprint can generate this automatically. If setting manually, use a long random value.
JWT_SECRET=<long-random-secret>

# After arbor-web exists, set the exact static site URL.
CORS_ORIGINS=https://<arbor-web>.onrender.com

# Public backend HTTPS URL. Required for Zadarma callbacks and client links.
PUBLIC_BASE_URL=https://<arbor-os>.onrender.com

# Render Free disk is ephemeral. Keep local only for smoke tests.
UPLOADS_DIR=/tmp/arbor-uploads
UPLOAD_STORAGE=s3

# Cloudflare R2 / S3-compatible storage for photos and quotation PDFs.
S3_BUCKET=<bucket-name>
S3_REGION=auto
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=<access-key-id>
S3_SECRET_ACCESS_KEY=<secret-access-key>
S3_PUBLIC_BASE_URL=https://<public-bucket-or-custom-domain>
S3_UPLOAD_PREFIX=uploads
S3_FORCE_PATH_STYLE=true

# Keep phone recordings local/temporary until telephony is configured.
PHONE_RECORDING_STORAGE=local
PHONE_RECORDINGS_DIR=/tmp/arbor-phone-recordings

# Neon Free pool tuning.
DB_POOL_MAX=5
DB_CONNECT_TIMEOUT_MS=10000
DB_IDLE_TIMEOUT_MS=10000

# Use memory for single-instance deploys, or redis for shared login limits.
LOGIN_RATE_LIMIT_STORE=memory
# LOGIN_RATE_LIMIT_STORE=redis
# LOGIN_RATE_LIMIT_REDIS_URL=redis://<user>:<password>@<redis-host>:6379

METRICS_ENABLED=false

# Optional, add later.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=
ZADARMA_API_KEY=
ZADARMA_API_SECRET=
ZADARMA_CALLER_ID=ARBOR
OPS_CRON_SECRET=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_PARSE_MODE=HTML

# Optional: notify sales when the public landing page demo form is submitted.
DEMO_REQUEST_WEBHOOK_URL=
DEMO_REQUEST_TELEGRAM_ENABLED=false
# Leave empty to reuse TELEGRAM_BOT_TOKEN / TELEGRAM_CHAT_ID, or set a sales-only chat.
DEMO_REQUEST_TELEGRAM_BOT_TOKEN=
DEMO_REQUEST_TELEGRAM_CHAT_ID=
DEMO_REQUEST_TELEGRAM_PARSE_MODE=HTML
OPENAI_API_KEY=
