# ARBOR-OS Render environment for arbo-os.com
# Paste these into Render -> arbor-os -> Environment.
# Replace DATABASE_URL and JWT_SECRET with real values.

NODE_ENV=production
TRUST_PROXY=1

# Use the Internal Database URL from Render Postgres service "arbor-db".
DATABASE_URL=<paste-internal-database-url-from-arbor-db>

# Use a long random value. Do not reuse this placeholder.
JWT_SECRET=<long-random-secret>

# Frontend domains allowed to call the API.
CORS_ORIGINS=https://arbo-os.com,https://www.arbo-os.com,https://arbo-web.onrender.com

# Public backend URL. After the new service is created, replace this with its
# Render URL, for example https://arbor-os-xxxx.onrender.com.
PUBLIC_BASE_URL=https://<new-arbor-os-service>.onrender.com

UPLOADS_DIR=/tmp/arbor-uploads
UPLOAD_STORAGE=local

PHONE_RECORDING_STORAGE=local
PHONE_RECORDINGS_DIR=/tmp/arbor-phone-recordings

DB_POOL_MAX=5
DB_CONNECT_TIMEOUT_MS=10000
DB_IDLE_TIMEOUT_MS=10000
LOGIN_RATE_LIMIT_STORE=memory
METRICS_ENABLED=false

# Optional integrations, add real values later.
ZADARMA_API_KEY=
ZADARMA_API_SECRET=
ZADARMA_CALLER_ID=ARBOR
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=
DEMO_REQUEST_WEBHOOK_URL=
DEMO_REQUEST_TELEGRAM_ENABLED=false
DEMO_REQUEST_TELEGRAM_BOT_TOKEN=
DEMO_REQUEST_TELEGRAM_CHAT_ID=
DEMO_REQUEST_TELEGRAM_PARSE_MODE=HTML
OPENAI_API_KEY=
